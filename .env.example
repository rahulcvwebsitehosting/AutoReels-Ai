# ============================================================
# WHICH LLM PROVIDER SHOULD GENERATE THE SCRIPT?
# ============================================================
# Set LLM_PROVIDER to one of:
#   gemini | openai | openrouter | groq | anthropic | ollama | opencode-zen
# If left blank, you'll get an interactive menu on startup.
# Default (when unset + menu skipped): gemini
LLM_PROVIDER=gemini

# ============================================================
# PEXELS (required for stock footage)
# ============================================================
PEXELS_API_KEY=your_pexels_api_key

# ============================================================
# GEMINI  (LLM_PROVIDER=gemini)
# ============================================================
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# ============================================================
# OPENAI  (LLM_PROVIDER=openai)
# ============================================================
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# OPENROUTER  (LLM_PROVIDER=openrouter)
# ============================================================
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openrouter/auto

# ============================================================
# GROQ  (LLM_PROVIDER=groq)
# ============================================================
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================
# ANTHROPIC  (LLM_PROVIDER=anthropic)
# ============================================================
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ============================================================
# OLLAMA  (LLM_PROVIDER=ollama)
# Local: leave OLLAMA_BASE_URL unset (defaults to localhost:11434/v1).
# Cloud: set OLLAMA_BASE_URL=https://ollama.com/v1 and provide your key.
# ============================================================
# OLLAMA_API_KEY=your_ollama_api_key
# OLLAMA_MODEL=llama3.1
# OLLAMA_BASE_URL=https://ollama.com/v1

# ============================================================
# OPENCODE ZEN  (LLM_PROVIDER=opencode-zen)
# ============================================================
OPENCODE_ZEN_API_KEY=your_opencode_zen_api_key
OPENCODE_ZEN_MODEL=openrouter/auto
